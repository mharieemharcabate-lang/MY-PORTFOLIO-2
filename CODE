#include <Wire.h>
#include <LiquidCrystal_I2C.h>

LiquidCrystal_I2C lcd(0x27, 16, 2);

int sensorPin = A0;
int relayPin = 7;

int moistureValue = 0;
int threshold = 500;

void setup() {
  pinMode(relayPin, OUTPUT);
  digitalWrite(relayPin, HIGH);
  lcd.init();
  lcd.backlight();

  lcd.setCursor(0, 0);
  lcd.print("Plant System");
  delay(2000);
  lcd.clear();
}

void loop() {
  moistureValue = analogRead(sensorPin);

  lcd.setCursor(0, 0);
  lcd.print("Moist:");
  lcd.print(moistureValue);
  lcd.print("   ");

  if (moistureValue > threshold) {
    
    digitalWrite(relayPin, HIGH);

    lcd.setCursor(0, 1);
    lcd.print("Pump: ON  Dry ");
  } else {
   
    digitalWrite(relayPin, LOW); 

    lcd.setCursor(0, 1);
    lcd.print("Pump: OFF Wet ");
  }

  delay(1000);
}
